# Vomero VM configuration. Copy to /etc/vomero/vomero.env and `chmod 600` it
# (it holds your API key). Loaded by the systemd unit.

# --- Isolation: Strategy A (per-step gVisor sandbox) ---
# This is the whole point of the VM: untrusted data, so model code runs in a
# throwaway gVisor container with NO network and NO access to the API key.
VOMERO_SANDBOX=1
VOMERO_SANDBOX_MEMORY=1g        # hard memory cap per run's container
VOMERO_SANDBOX_CPUS=2           # vCPUs per run's container

# --- Data locations on the VM ---
VOMERO_DATA_ROOT=/data                          # INPUT: dataset store, mounted read-only
VOMERO_WORKSPACE_ROOT=/var/lib/vomero/workspace # OUTPUT: where the model writes result files

# --- Model / credentials ---
VOMERO_PROVIDER=openai
VOMERO_MODEL=gpt-4o-mini
OPENAI_API_KEY=sk-REPLACE_ME
# Gemini instead:  VOMERO_PROVIDER=gemini  VOMERO_MODEL=gemini-2.5-flash  GEMINI_API_KEY=...

# --- Cost / lifetime ceilings ---
VOMERO_MAX_STEPS=16             # REPL steps per question
VOMERO_MAX_DEPTH=2              # recursion depth
VOMERO_SESSION_TTL=900          # idle seconds before a session's variables are dropped
