# Copy to .env and fill in. .env is gitignored.

# --- Provider selection ---
# "openai" (any OpenAI-compatible server) or "gemini".
VOMERO_PROVIDER=openai

# Model name as the provider expects it.
VOMERO_MODEL=gpt-4o-mini

# --- Credentials / endpoint ---
# For OpenAI: just set the API key, leave base_url unset.
OPENAI_API_KEY=sk-...

# For an OpenAI-compatible server (vLLM, LM Studio, OpenRouter, Together, ...):
# VOMERO_BASE_URL=http://localhost:1234/v1
# VOMERO_API_KEY=not-needed-for-local

# For Google Gemini (uses its OpenAI-compatible endpoint; base_url is automatic):
# VOMERO_PROVIDER=gemini
# VOMERO_MODEL=gemini-2.5-flash
# GEMINI_API_KEY=...            # or VOMERO_API_KEY / GOOGLE_API_KEY

# --- Ranked search (optional) ---
# The source's search() primitive uses pure-Python BM25 by default (no setup).
# Set an embedding model to ALSO run dense retrieval and fuse them (hybrid),
# catching paraphrase a keyword match misses. Uses the chat endpoint/key unless
# overridden. Leave unset for lexical-only search.
# VOMERO_EMBEDDING_MODEL=text-embedding-3-small
# VOMERO_EMBEDDING_BASE_URL=        # defaults to VOMERO_BASE_URL
# VOMERO_EMBEDDING_API_KEY=         # defaults to the chat API key

# Where search() runs, in precedence order:
#  1. External retrieval service (RemoteBackend) — the scalable, multi-tenant
#     path. The vectors, the index, and query-embedding all live in the service,
#     so the serving process holds NO retrieval state (flat memory, stateless).
# VOMERO_RETRIEVAL_URL=https://retrieval.internal/search
# VOMERO_RETRIEVAL_COLLECTION=my-corpus
# VOMERO_RETRIEVAL_API_KEY=
#  2. A prebuilt persistent index dir (see `vomero index`), opened read-only —
#     typically a read-only volume mounted into the pod. Used when no URL is set.
# VOMERO_INDEX_DIR=/data/my-corpus.idx
#  3. (neither set) a lazy in-memory index built on first search — dev/small only.

# --- RLM loop limits (optional) ---
# VOMERO_MAX_STEPS=24
# VOMERO_MAX_DEPTH=3

# --- Execution backend: how the model's REPL code is isolated -----------------
#   inprocess  (default) run on the machine with exec(): fast, full-power, NOT
#              isolated. Fine for local dev on trusted data.
#   gvisor     each REPL step runs in a gVisor container (needs Docker + runsc).
# VOMERO_EXEC_BACKEND=inprocess     # inprocess | gvisor
# (Legacy: VOMERO_SANDBOX=1 maps to gvisor when VOMERO_EXEC_BACKEND is unset.)

# Knobs for VOMERO_EXEC_BACKEND=gvisor:
# VOMERO_SANDBOX_MEMORY=512m        # hard memory cap (e.g. 1g, 2g)
# VOMERO_SANDBOX_CPUS=1.0           # fractional vCPUs (e.g. 0.5, 2)
# VOMERO_SANDBOX_IMAGE=python:3.11-slim   # image with the deps the code needs
# VOMERO_SANDBOX_RUNTIME=runsc            # OCI runtime (gVisor)
# VOMERO_SANDBOX_NETWORK=none             # docker --network
# VOMERO_SANDBOX_PIDS=256                 # max processes (fork-bomb guard)
# VOMERO_SANDBOX_STARTUP_TIMEOUT=60       # seconds (first run may pull the image)

# --- Sandboxed runner (vomero-in-the-pod) -------------------------------------
# A DEPLOYMENT topology, not an exec backend: the host is a thin dispatcher and
# each request runs the WHOLE engine inside a hardened Kubernetes worker pod
# (warm pool, via vomero_sandbox). The engine inside the pod runs inprocess.
# Used by main.py / vomero.sandbox_runner.SandboxedRunner. Needs:
#   pip install 'vomero[k8s]', a reachable cluster, and a worker image with
#   vomero baked in (deploy/worker.Dockerfile) loaded into the cluster.
# VOMERO_K8S_SANDBOX_IMAGE=vomero-worker:latest   # image with vomero installed
# VOMERO_K8S_SANDBOX_NAMESPACE=sandbox
# VOMERO_K8S_SANDBOX_POOL_SIZE=3               # warm pods == concurrency ceiling
# VOMERO_K8S_SANDBOX_RUNTIME_CLASS=gvisor      # kernel isolation (needs cluster setup)
# VOMERO_K8S_SANDBOX_TIMEOUT=120               # per-request wall-clock seconds (a full run)
# VOMERO_K8S_SANDBOX_KUBE_CONTEXT=             # blank = default kubeconfig context
#
# Egress — the pod must reach the LLM endpoint. Pick ONE:
#   Production: keep the default-deny policy (MANAGE_NETPOL unset/1) and route
#               through an allowlisting proxy:
# VOMERO_K8S_SANDBOX_EGRESS_PROXY=http://egress-proxy.sandbox.svc:3128
#   Dev/test:   no proxy yet — skip the deny-all policy so the pod can reach out:
# VOMERO_K8S_SANDBOX_MANAGE_NETPOL=0

# --- Sessions & heavy-load guardrails (server) ---------------------------------
# Per-session persistence: a warm env (variables + workspace) is kept per
# (user_id, session_id) so follow-ups resume state.
# VOMERO_SESSION_TTL=900            # idle seconds before a session's env is dropped
#                                   # (lower to 120-300 under load to free memory sooner)
# VOMERO_WORKSPACE_ROOT=/var/lib/vomero/workspaces  # durable per-session files
# Admission control — set BOTH in any multi-user deployment so the node fails
# gracefully (429 / LRU eviction) instead of OOMing under load. 0 = unlimited.
# VOMERO_MAX_CONCURRENT_RUNS=8      # in-flight runs per replica; size to
#                                   # node_mem / per-container-mem, NOT CPU
# VOMERO_MAX_SESSIONS=64            # warm/idle session envs kept (LRU past this)
